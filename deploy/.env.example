APP_ENV=production
APP_URL=https://rc.example.com
MAIL_ENABLED=false

DB_HOST=db
DB_NAME=wwgepr_crm_antigo
DB_USER=rc_app
DB_PASS=CHANGE_ME_DB_PASS
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASS
MYSQL_CHARACTER_SET_SERVER=latin1
